<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0"
            prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RoleSelectController">

    <children>

        <Button layoutX="200.0"
                layoutY="120.0"
                prefHeight="50.0"
                prefWidth="200.0"
                text="Login as Employee"
                onAction="#selectEmployee"/>

        <Button layoutX="200.0"
                layoutY="220.0"
                prefHeight="50.0"
                prefWidth="200.0"
                text="Login as Admin"
                onAction="#selectAdmin"/>

    </children>

</AnchorPane>