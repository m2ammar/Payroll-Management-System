<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AdminSelectController"
      spacing="16" alignment="CENTER"
      prefWidth="420" prefHeight="440"
      style="-fx-background-color: #1e1e2e;">
    <padding><Insets top="50" bottom="50" left="50" right="50"/></padding>

    <Label text="Payroll Management System"
           style="-fx-text-fill: #cdd6f4; -fx-font-size: 21px; -fx-font-weight: bold;"/>
    <Label text="Select your admin type"
           style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>

    <VBox spacing="14" alignment="CENTER">
        <Button text="👑  Super Admin" onAction="#selectSuperAdmin"
                maxWidth="Infinity" prefHeight="58"
                style="-fx-background-color: #cba6f7; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="📋  Sub Admin" onAction="#selectSubAdmin"
                maxWidth="Infinity" prefHeight="58"
                style="-fx-background-color: #89dceb; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
    </VBox>

    <Button text="← Back" onAction="#goBack"
            style="-fx-background-color: transparent; -fx-text-fill: #585b70;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>
</VBox>
